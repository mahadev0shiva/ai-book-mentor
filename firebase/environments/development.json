{
  "environment": "development",
  "projectId": "aistudio-book-study-dev",
  "auth": {
    "allowAnonymous": true,
    "requireEmailVerification": false
  },
  "features": {
    "enableOcrPipeline": true,
    "enableIllustrationGeneration": true,
    "maxUploadSizeMb": 50,
    "rateLimitRequestsPerMin": 60
