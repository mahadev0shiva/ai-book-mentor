{
  "environment": "staging",
  "projectId": "aistudio-book-study-staging",
  "auth": {
    "allowAnonymous": false,
    "requireEmailVerification": true
  },
  "features": {
    "enableOcrPipeline": true,
    "enableIllustrationGeneration": true,
    "maxUploadSizeMb": 100,
    "rateLimitRequestsPerMin": 120
